      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 03 - Perfiles de Riesgo\n",
        "\n",
        "Construye los sub-universos por perfil del Informe 1 y optimiza Markowitz para cada uno. La comparaci?n por perfil es contra el benchmark equiponderado top 20 por capitalizaci?n burs?til del universo F5. La optimizaci?n usa media-varianza con gamma, retornos semanales totales y covarianza con shrinkage."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from pathlib import Path\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "from markowitz_pipeline import (\n",
        "    PROFILE_ORDER,\n",
        "    benchmark_top20_equal_weight,\n",
        "    load_prepared_outputs,\n",
        "    resolve_paths,\n",
        "    run_profiles,\n",
        "    save_final_outputs,\n",
        ")\n",
        "\n",
        "paths = resolve_paths(Path(r\"X:/capstone/Modelo_finanzas\"))\n",
        "universe_f5, daily_returns, weekly_returns, mu, sigma = load_prepared_outputs(paths)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "estimation_returns = pd.read_pickle(paths.outputs_dir / "estimation_returns.pkl")
subuniverses, summary, weights = run_profiles(universe_f5, estimation_returns)\n",
        "benchmark, benchmark_metrics = benchmark_top20_equal_weight(universe_f5, estimation_returns)\n",
        "outputs = save_final_outputs(subuniverses, summary, weights, benchmark, paths)\n",
        "outputs"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "summary[[\n",
        "    \"profile\", \"subuniverse_size\",\n",
        "    \"annual_return_markowitz\", \"annual_volatility_markowitz\", \"sharpe_markowitz\",\n",
        "    \"annual_return_equal_weight\", \"annual_volatility_equal_weight\", \"sharpe_equal_weight\",\n",
        "    \"delta_sharpe\", \"top5_weight\", \"top10_weight\", \"hhi\", \"optimizer_success\"\n",
        "]]"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "subuniverses.groupby([\"profile\", \"sector\"]).size().unstack(fill_value=0).loc[PROFILE_ORDER]"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Top tickers por perfil\n",
        "(\n",
        "    weights.sort_values([\"profile\", \"weight\"], ascending=[True, False])\n",
        "    .groupby(\"profile\")\n",
        "    .head(10)\n",
        "    [[\"profile\", \"ticker\", \"sector\", \"weight\", \"equal_weight\", \"market_cap\", \"short_name\"]]\n",
        ")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "assert set(summary[\"profile\"]) == set(PROFILE_ORDER)\n",
        "assert summary[\"optimizer_success\"].all()\n",
        "for profile, grp in weights.groupby(\"profile\"):\n",
        "    assert np.isclose(grp[\"weight\"].sum(), 1.0, atol=1e-6), profile\n",
        "print(\"Validaciones por perfil OK\")"
      ]
    }
  ],
