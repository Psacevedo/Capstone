{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 04 - Resultados Finales\n",
        "\n",
        "Genera las tablas finales para la entrega: Markowitz media-varianza por perfil, portafolio equiponderado top 20 por market cap, delta Sharpe, concentraci?n sectorial y top tickers."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from pathlib import Path\n",
        "import ast\n",
        "import pandas as pd\n",
        "\n",
        "from markowitz_pipeline import benchmark_top20_equal_weight, load_prepared_outputs, resolve_paths\n",
        "\n",
        "paths = resolve_paths(Path(r\"X:/capstone/Modelo_finanzas\"))\n",
        "universe_f5, daily_returns, weekly_returns, mu, sigma = load_prepared_outputs(paths)\n",
        "summary = pd.read_csv(paths.outputs_dir / \"markowitz_profiles_summary.csv\")\n",
        "weights = pd.read_csv(paths.outputs_dir / \"markowitz_profile_weights.csv\")\n",
        "benchmark = pd.read_csv(paths.outputs_dir / \"benchmark_top20_equal_weight.csv\")\n",
        "estimation_returns = pd.read_pickle(paths.outputs_dir / "estimation_returns.pkl")
_, benchmark_metrics = benchmark_top20_equal_weight(universe_f5, estimation_returns)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "final_table = summary[[\n",
        "    \"profile\", \"subuniverse_size\",\n",
        "    \"annual_return_markowitz\", \"annual_volatility_markowitz\", \"sharpe_markowitz\",\n",
        "    \"annual_return_equal_weight\", \"annual_volatility_equal_weight\", \"sharpe_equal_weight\",\n",
        "    \"delta_sharpe\", \"top5_weight\", \"top10_weight\", \"hhi\"\n",
        "]].copy()\n",
        "\n",
        "pct_cols = [\n",
        "    \"annual_return_markowitz\", \"annual_volatility_markowitz\",\n",
        "    \"annual_return_equal_weight\", \"annual_volatility_equal_weight\",\n",
        "    \"top5_weight\", \"top10_weight\",\n",
        "]\n",
        "for col in pct_cols:\n",
        "    final_table[col] = final_table[col] * 100\n",
        "\n",
        "final_table.round(4)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "print(\"Benchmark equiponderado top 20 market cap\")\n",
        "print(benchmark_metrics)\n",
        "benchmark"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "sector_concentration = (\n",
        "    weights.groupby([\"profile\", \"sector\"], as_index=False)[\"weight\"].sum()\n",
        "    .sort_values([\"profile\", \"weight\"], ascending=[True, False])\n",
        ")\n",
        "sector_concentration[\"weight_pct\"] = sector_concentration[\"weight\"] * 100\n",
        "sector_concentration"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "top_tickers = (\n",
        "    weights.sort_values([\"profile\", \"weight\"], ascending=[True, False])\n",
        "    .groupby(\"profile\")\n",
        "    .head(10)\n",
        "    .copy()\n",
        ")\n",
        "top_tickers[\"weight_pct\"] = top_tickers[\"weight\"] * 100\n",
        "top_tickers[[\"profile\", \"ticker\", \"sector\", \"weight_pct\", \"short_name\"]]"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Exportes finales adicionales en formato ancho para insertar en informe.\n",
        "final_table.to_csv(paths.outputs_dir / \"tabla_final_markowitz_vs_equiponderado.csv\", index=False)\n",
        "sector_concentration.to_csv(paths.outputs_dir / \"concentracion_sectorial_por_perfil.csv\", index=False)\n",
        "top_tickers.to_csv(paths.outputs_dir / \"top_tickers_por_perfil.csv\", index=False)\n",
        "\n",
        "print(\"Archivos finales generados en\", paths.outputs_dir)"
      ]
    }
  ],
